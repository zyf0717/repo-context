[explorer]
max_turns = 6
citation = true
ignore = [".git", ".venv", "node_modules", "dist", "build"]
traj_dir = ".fastcontext"

[model]
base_url = "http://localhost:8000/v1"
model = "your-model-name"
api_key = ""
timeout_seconds = 120
max_completion_tokens = 512
temperature = 0

[tools]
max_read_bytes = 12000
max_grep_results = 50
max_observation_chars = 6000
max_read_lines = 120
